#!/usr/bin/env bash
# ============================================================
# Laji-HoneyPot 管理端运维工具 v0.19.0
# 用法: ./honeypot-ctl {start|stop|restart|status|update|logs|build|clean|password|help}
# ============================================================
set -euo pipefail

# ---------- 颜色定义 ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ---------- 配置 ----------
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$PROJECT_ROOT/.honeypot.pid"
LOG_FILE="$PROJECT_ROOT/honeypot.log"
BINARY="$PROJECT_ROOT/bin/honeypot"
API_ADDR="${API_ADDR:-127.0.0.1:8080}"
API_URL="http://${API_ADDR}"

# ---------- 工具函数 ----------
log_info()  { echo -e "${GREEN}[INFO]${NC}  $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }
log_step()  { echo -e "${CYAN}[STEP]${NC}  $*"; }

# ---- PATH 恢复（针对 trae-sandbox 环境 PATH 退化） ----
ensure_path() {
    local missing=()
    local restored=()
    for cmd in go node npm git curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done
    if [ ${#missing[@]} -eq 0 ]; then
        return 0
    fi
    local extra_paths="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:$HOME/go/bin"
    for nvm_dir in "$HOME/.nvm/versions/node"/*; do
        if [ -d "$nvm_dir/bin" ]; then
            extra_paths="$extra_paths:$nvm_dir/bin"
        fi
    done 2>/dev/null
    export PATH="${extra_paths}:${PATH}"
    for cmd in "${missing[@]}"; do
        if command -v "$cmd" >/dev/null 2>&1; then
            restored+=("$cmd")
        fi
    done
    local still_missing=()
    for cmd in "${missing[@]}"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            still_missing+=("$cmd")
        fi
    done
    if [ ${#restored[@]} -gt 0 ]; then
        log_warn "PATH 恢复: ${restored[*]} 已恢复可用"
    fi
    if [ ${#still_missing[@]} -gt 0 ]; then
        log_warn "PATH 恢复不完全，以下命令仍不可用: ${still_missing[*]}"
    fi
}

banner() {
    echo -e "${BOLD}${BLUE}"
    echo "  =============================================="
    echo "        Laji-HoneyPot Management CLI v0.19.0"
    echo "  =============================================="
    echo -e "${NC}"
}

# 获取运行中的进程 PID（优先从 PID 文件，其次 ps 查找）
get_pid() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE" 2>/dev/null || true)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            echo "$pid"
            return 0
        fi
    fi
    # 从进程列表查找
    pgrep -f "bin/honeypot" 2>/dev/null | head -1 || true
}

# 检查服务是否运行
is_running() {
    local pid
    pid=$(get_pid)
    [ -n "$pid" ]
}

# ---------- 核心命令 ----------

cmd_clean() {
    log_step "清理编译产物和临时文件..."
    cd "$PROJECT_ROOT"
    
    # 停止运行中的服务
    if is_running; then
        log_warn "检测到运行中的服务，正在停止..."
        cmd_stop
    fi

    # 清理编译产物
    local cleaned=0
    if [ -f "$BINARY" ]; then
        rm -f "$BINARY"
        log_info "已删除: $BINARY"
        cleaned=1
    fi
    if [ -f "bin/honeypot-windows-amd64.exe" ]; then
        rm -f bin/honeypot-windows-amd64.exe
        cleaned=1
    fi
    if [ -f "bin/honeypot-linux-amd64" ]; then
        rm -f bin/honeypot-linux-amd64
        cleaned=1
    fi
    if [ -f "honeypot" ]; then
        rm -f honeypot
        cleaned=1
    fi
    
    # 清理部署包产物
    rm -f deploy/agent-package-*.zip 2>/dev/null || true
    rm -f deploy/win-agent/honeypot-agent.exe 2>/dev/null || true
    rm -f deploy/win-agent/agent-package.zip 2>/dev/null || true
    rm -f deploy/win-agent/config.yaml 2>/dev/null || true
    rm -f deploy/win-agent/deploy.sh 2>/dev/null || true
    rm -f deploy/win-agent/README.txt 2>/dev/null || true
    
    # 清理前端构建产物
    if [ -d "web-dist" ]; then
        rm -rf web-dist
        log_info "已删除: web-dist/"
        cleaned=1
    fi

    # 清理 PID 文件和日志
    rm -f "$PID_FILE"
    
    # Go 构建缓存清理
    go clean -cache 2>/dev/null || true
    
    if [ "$cleaned" -eq 0 ]; then
        log_info "没有需要清理的文件"
    else
        log_info "清理完成"
    fi
}

cmd_build() {
    log_step "编译 honeypot 二进制文件 (覆盖旧产物)..."
    cd "$PROJECT_ROOT"
    
    # 确保 bin/ 目录存在
    mkdir -p bin/
    
    # 编译前删除旧二进制（覆盖规则）
    rm -f "$BINARY"
    
    # Go mod 依赖检查
    if [ ! -f "go.sum" ]; then
        log_step "下载 Go 依赖..."
        go mod download 2>&1 || true
    fi
    
    if ! go build -o "$BINARY" ./cmd/honeypot/ 2>&1; then
        log_error "编译失败，请检查 Go 环境和项目依赖"
        return 1
    fi
    log_info "编译成功: $BINARY ($(du -sh "$BINARY" 2>/dev/null | cut -f1))"
}

cmd_start() {
    banner
    if is_running; then
        local pid
        pid=$(get_pid)
        log_warn "服务已在运行 (PID: $pid)"
        echo "  如需重启请执行: $0 restart"
        return 0
    fi

    # 检查二进制文件
    if [ ! -f "$BINARY" ]; then
        log_info "未找到编译产物 ($BINARY)，自动编译中..."
        cmd_build || return 1
    fi

    # 检测首次运行（配置中无 admin_password_hash）
    local first_run=false
    if [ -f "$PROJECT_ROOT/config.yaml" ]; then
        if ! grep -q 'admin_password_hash' "$PROJECT_ROOT/config.yaml" 2>/dev/null; then
            first_run=true
        fi
    else
        first_run=true
    fi

    # 启动服务
    log_step "启动 honeypot 服务..."
    cd "$PROJECT_ROOT"
    nohup "$BINARY" >> "$LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"

    # 等待启动
    sleep 2
    if kill -0 "$pid" 2>/dev/null; then
        log_info "服务启动成功 (PID: $pid)"
        echo "  API 地址:   $API_URL"
        echo "  日志文件:   $LOG_FILE"
        echo "  查看状态:   $0 status"
        echo "  查看日志:   $0 logs"

        # 首次运行：从日志中提取初始密码
        if [ "$first_run" = true ]; then
            # 再等 1 秒确保密码写入日志
            sleep 1
            echo ""
            if grep -A 20 '管理端初始密码' "$LOG_FILE" 2>/dev/null | head -20; then
                echo ""
                log_warn "⚠️  以上为首次启动自动生成的强密码，请立即登录修改！"
                echo "  此后密码不再显示，如需再次查看请执行: $0 password"
            else
                log_warn "首次运行已生成强密码，请查看日志文件获取初始密码:"
                echo "  tail -30 $LOG_FILE"
                echo ""
                echo "  或执行: $0 password"
            fi
        fi
    else
        log_error "服务启动失败，请查看日志: $LOG_FILE"
        rm -f "$PID_FILE"
        return 1
    fi
}

cmd_stop() {
    local pid
    pid=$(get_pid)
    if [ -z "$pid" ]; then
        log_info "服务未在运行"
        rm -f "$PID_FILE"
        return 0
    fi

    log_step "停止 honeypot 服务 (PID: $pid)..."
    kill "$pid" 2>/dev/null || true

    # 等待优雅退出（最多 10 秒）
    local waited=0
    while kill -0 "$pid" 2>/dev/null && [ $waited -lt 10 ]; do
        sleep 1
        waited=$((waited + 1))
    done

    # 如果还没退出，强制终止
    if kill -0 "$pid" 2>/dev/null; then
        log_warn "服务未在 10 秒内停止，强制终止..."
        kill -9 "$pid" 2>/dev/null || true
        sleep 1
    fi

    rm -f "$PID_FILE"
    log_info "服务已停止"
}

cmd_restart() {
    log_step "重启 honeypot 服务..."
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    local pid
    pid=$(get_pid)

    echo -e "${BOLD}Laji-HoneyPot 服务状态${NC}"
    echo "------------------------------------------"

    if [ -z "$pid" ]; then
        echo -e "  状态:     ${RED}未运行${NC}"
        rm -f "$PID_FILE"
        return 1
    fi

    echo -e "  状态:     ${GREEN}运行中${NC}"
    echo "  PID:      $pid"

    # 运行时长
    local elapsed
    elapsed=$(ps -o etime= -p "$pid" 2>/dev/null | xargs)
    echo "  运行时长: ${elapsed:-未知}"

    # 内存使用
    local mem
    mem=$(ps -o rss= -p "$pid" 2>/dev/null | xargs)
    if [ -n "$mem" ]; then
        local mem_mb
        mem_mb=$(echo "scale=1; $mem / 1024" | bc 2>/dev/null || echo "$mem")
        echo "  内存:     ${mem_mb}MB"
    fi

    # API 健康检查
    echo ""
    echo -e "${BOLD}API 健康检查${NC}"
    echo "------------------------------------------"
    local hc_output hc_code hc_time
    hc_output=$(curl -s -w "\n%{http_code}\n%{time_total}" "$API_URL/healthz" 2>/dev/null || true)
    hc_code=$(echo "$hc_output" | tail -2 | head -1)
    hc_time=$(echo "$hc_output" | tail -1)

    case "$hc_code" in
        200)
            echo -e "  /healthz:  ${GREEN}$hc_code OK${NC} (${hc_time}s)"
            hc_body=$(echo "$hc_output" | head -n -2)
            echo "  响应:     $hc_body"
            ;;
        *)
            echo -e "  /healthz:  ${RED}不可达${NC}"
            ;;
    esac

    # 服务状态详情
    local svc_output svc_code
    svc_output=$(curl -s -w "\n%{http_code}" "$API_URL/api/services/status" 2>/dev/null || true)
    svc_code=$(echo "$svc_output" | tail -1)
    if [ "$svc_code" = "200" ]; then
        echo ""
        echo -e "${BOLD}蜜罐服务运行状态${NC}"
        echo "------------------------------------------"
        echo "$svc_output" | head -n -1 | python3 -m json.tool 2>/dev/null || echo "$svc_output"
    fi

    return 0
}

cmd_update() {
    banner
    log_step "开始版本更新..."

    cd "$PROJECT_ROOT"

    # 1. 检查是否有未提交的变更
    if [ -n "$(git status --porcelain 2>/dev/null || true)" ]; then
        log_warn "检测到本地未提交的变更:"
        git status --short
        echo ""
        echo -n "是否继续更新? (本地变更可能被覆盖) [y/N]: "
        read -r confirm
        if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
            log_info "更新已取消"
            return 0
        fi
    fi

    # 2. 拉取最新代码
    log_step "拉取最新代码..."
    if git pull --ff-only 2>&1; then
        log_info "代码拉取成功"
    else
        log_warn "代码拉取失败，尝试强制同步..."
        git fetch origin 2>&1 || {
            log_error "无法连接到远程仓库，请检查网络和 Git 配置"
            return 1
        }
        git reset --hard origin/HEAD 2>&1 || {
            log_error "代码同步失败"
            return 1
        }
    fi

    # 3. 记录当前版本
    local old_ver
    old_ver=$(grep 'const Version' internal/core/version.go 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' || echo "unknown")

    # 4. 清理旧产物（覆盖规则）然后编译
    local was_running=false
    if is_running; then
        was_running=true
        cmd_stop
    fi

    # 覆盖旧编译产物
    cmd_clean
    cmd_build || return 1

    # 5. 构建前端（如果 web/ 存在且有变更）
    if [ -d "$PROJECT_ROOT/web" ] && [ -f "$PROJECT_ROOT/web/package.json" ]; then
        log_step "检查前端是否需要重新构建..."
        if [ -d "$PROJECT_ROOT/web/node_modules" ]; then
            cd "$PROJECT_ROOT/web"
            if npm run build 2>&1; then
                log_info "前端构建成功"
            else
                log_warn "前端构建失败，将使用已有构建产物"
            fi
            cd "$PROJECT_ROOT"
        else
            log_step "安装前端依赖并构建..."
            cd "$PROJECT_ROOT/web"
            if npm install 2>&1 && npm run build 2>&1; then
                log_info "前端依赖安装及构建成功"
            else
                log_warn "前端构建失败"
            fi
            cd "$PROJECT_ROOT"
        fi
    fi

    # 6. 重启服务
    if [ "$was_running" = true ]; then
        log_step "重启服务..."
        sleep 1
        cmd_start
    else
        log_info "更新完成。如需启动服务请执行: $0 start"
    fi

    # 7. 显示版本变更
    local new_ver
    new_ver=$(grep 'const Version' internal/core/version.go 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' || echo "unknown")
    echo ""
    log_info "版本更新: ${old_ver} -> ${new_ver}"
}

cmd_logs() {
    local lines="${1:-50}"
    if [ -f "$LOG_FILE" ]; then
        echo -e "${BOLD}最近 $lines 行日志 ($LOG_FILE)${NC}"
        echo "------------------------------------------"
        tail -n "$lines" "$LOG_FILE"
    else
        log_warn "日志文件不存在: $LOG_FILE"
    fi
}

# 从日志中提取首次启动生成的初始密码
cmd_password() {
    echo -e "${BOLD}Laji-HoneyPot 初始密码${NC}"
    echo "------------------------------------------"

    if [ -f "$PROJECT_ROOT/config.yaml" ]; then
        if grep -q 'admin_password_hash' "$PROJECT_ROOT/config.yaml" 2>/dev/null; then
            # 配置中已有密码哈希，尝试从所有日志文件提取（含轮转日志）
            local found=false
            local log_files=("$LOG_FILE" "$LOG_FILE".*)
            for lf in "${log_files[@]}"; do
                if [ -f "$lf" ] && grep -q '管理端初始密码' "$lf" 2>/dev/null; then
                    echo ""
                    echo -e "${CYAN}来源: $lf${NC}"
                    grep -A 20 '管理端初始密码' "$lf" 2>/dev/null | head -20
                    echo ""
                    log_warn "以上密码已在首次启动时生成，请妥善保管！"
                    echo "  如已忘记，可通过管理端 UI 重新设置管理员密码。"
                    found=true
                    break
                fi
            done

            if [ "$found" = false ]; then
                echo ""
                log_warn "所有日志中均未找到初始密码记录（可能已被清理或日志轮转）"
                echo ""
                echo -e "  ${BOLD}如何重置管理员密码:${NC}"
                echo "  1. 用你熟悉的编辑器打开 config.yaml"
                echo "  2. 删除 admin_password_hash 这一行"
                echo "  3. 执行: $0 restart"
                echo "  4. 新密码将自动生成并显示在终端"
                echo ""
                echo -e "  ${BOLD}一键重置命令:${NC}"
                echo "  sed -i '' '/admin_password_hash/d' $PROJECT_ROOT/config.yaml && $0 restart"
            fi
        else
            log_info "尚未生成管理员密码（首次启动时自动生成）"
            echo "  请执行 '$0 start' 启动服务，密码将自动生成并显示。"
        fi
    else
        log_info "配置文件不存在，首次启动时将自动生成管理员强密码"
        echo "  请执行 '$0 start' 启动服务。"
    fi
}

# ---------- 帮助 ----------
cmd_help() {
    banner
    echo "用法: $0 {start|stop|restart|status|update|logs|build|clean|password|help}"
    echo ""
    echo "命令:"
    echo "  start     编译并启动 honeypot 服务"
    echo "  stop      停止 honeypot 服务"
    echo "  restart   重启 honeypot 服务"
    echo "  status    查看服务运行状态、API 健康检查、蜜罐服务状态"
    echo "  update    一键更新: git pull -> clean -> build -> 重启"
    echo "  logs [N]  查看最近 N 行日志 (默认 50)"
    echo "  build     编译二进制 (自动删除旧产物, 覆盖写入 bin/honeypot)"
    echo "  clean     清理所有编译产物、构建缓存、部署包临时文件"
    echo "  password  查看首次启动自动生成的初始强密码"
    echo "  help      显示帮助信息"
    echo ""
    echo "环境变量:"
    echo "  API_ADDR  API 监听地址 (默认: 127.0.0.1:8080)"
    echo ""
    echo "文件:"
    echo "  PID 文件:   $PID_FILE"
    echo "  日志文件:   $LOG_FILE"
    echo "  配置:       $PROJECT_ROOT/config.yaml"
    echo "  二进制:     $BINARY"
    echo ""
    echo "测试:"
    echo "  全量测试:   bash scripts/full-test.sh"
    echo "  快速验证:   bash deploy/quick-verify.sh"
    echo ""
    echo "示例:"
    echo "  $0 start                    # 编译 + 启动"
    echo "  $0 build                    # 仅编译 (覆盖旧产物)"
    echo "  $0 clean                    # 清理所有产物"
    echo "  $0 status                   # 查看运行状态"
    echo "  $0 update                   # 一键更新到最新版本"
    echo "  $0 logs 100                 # 最近 100 行日志"
    echo "  $0 restart                  # 重启服务"
    echo "  $0 password                 # 查看初始管理员密码"
}

# ---------- 入口 ----------
ensure_path

case "${1:-help}" in
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    update)   cmd_update ;;
    logs)     cmd_logs "${2:-50}" ;;
    build)    cmd_build ;;
    clean)    cmd_clean ;;
    password) cmd_password ;;    
    help|--help|-h) cmd_help ;;
    *)
        log_error "未知命令: ${1:-}"
        echo "  运行 '$0 help' 查看可用命令"
        exit 1
        ;;
esac
